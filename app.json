{
  "expo": {
    "name": "Local Social",
    "slug": "local-social",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "localsocial",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1116"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dahacker.localsocial",
      "buildNumber": "9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e1116"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed3d409b-4469-4397-b8b5-26fe58e8b895"
      }
    }
  }
}
